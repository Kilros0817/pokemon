{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pokemon App Database Schema",
  "type": "object",
  "properties": {
    "trainers": {
      "type": "array",
      "items": { "$ref": "#/definitions/trainer" }
    },
    "teams": {
      "type": "array",
      "items": { "$ref": "#/definitions/team" }
    },
    "battles": {
      "type": "array",
      "items": { "$ref": "#/definitions/battle" }
    },
    "battle_log": {
      "type": "array",
      "items": { "$ref": "#/definitions/battleLogEntry" }
    }
  },
  "required": ["trainers", "teams", "battles", "battle_log"],
  "additionalProperties": false,
  "definitions": {
    "trainer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "password": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "badge_count": { "type": "integer" },
        "region": { "type": "string" },
        "avatar_url": { "type": "string" },
        "rank": { "type": "string" }
      },
      "required": ["id", "email", "password", "firstName", "lastName"],
      "additionalProperties": false
    },
    "team": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trainer_id": { "type": "string" },
        "name": { "type": "string" },
        "pokemon_slots": {
          "type": "array",
          "items": { "$ref": "#/definitions/pokemonSlot" }
        },
        "created_at": { "type": "string", "format": "date-time" },
        "competitive_mode": { "type": "boolean" },
        "tier": { "type": ["string", "null"] }
      },
      "required": ["id", "trainer_id", "name", "pokemon_slots", "created_at"],
      "additionalProperties": false
    },
    "pokemonSlot": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "nickname": { "type": "string" },
        "held_item": { "type": "string" },
        "ev_spread": {
          "type": "object",
          "properties": {
            "hp": { "type": "integer", "minimum": 0, "maximum": 252 },
            "attack": { "type": "integer", "minimum": 0, "maximum": 252 },
            "defense": { "type": "integer", "minimum": 0, "maximum": 252 },
            "sp_attack": { "type": "integer", "minimum": 0, "maximum": 252 },
            "sp_defense": { "type": "integer", "minimum": 0, "maximum": 252 },
            "speed": { "type": "integer", "minimum": 0, "maximum": 252 }
          },
          "required": ["hp", "attack", "defense", "sp_attack", "sp_defense", "speed"],
          "additionalProperties": false
        }
      },
      "required": ["id", "nickname", "held_item", "ev_spread"],
      "additionalProperties": false
    },
    "battle": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trainer_id": { "type": "string" },
        "opponent_name": { "type": "string" },
        "team_id": { "type": "string" },
        "result": { "type": "string", "enum": ["win", "loss"] },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "score_trainer": { "type": "integer" },
        "score_opponent": { "type": "integer" }
      },
      "required": ["id", "trainer_id", "opponent_name", "team_id", "result", "date", "score_trainer", "score_opponent"],
      "additionalProperties": false
    },
    "battleLogEntry": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "battle_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["success", "info", "danger"] }
      },
      "required": ["id", "battle_id", "timestamp", "message", "severity"],
      "additionalProperties": false
    }
  }
}
